# Core runtime
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# Auth
JWT_SECRET=replace-with-strong-secret

# Frontend origin (used for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Google OAuth (required for production config)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email credentials
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password

# Optional SMTP overrides
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM="\"Workzup\" <noreply@workzup.com>"

# Supabase (if used by auth/messaging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# PayHere
PAYHERE_MERCHANT_ID=your-payhere-merchant-id
PAYHERE_MERCHANT_SECRET=your-payhere-merchant-secret
PAYHERE_SANDBOX=true
API_BASE_URL=http://localhost:5000
